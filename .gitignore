# ──────────────────────────────────────
# ReviewOps AI — .gitignore
# ──────────────────────────────────────

# Documentation (kept local, not version-controlled)
docs/

# ──────────────── Python ────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/

# ──────────────── Node / Frontend ────────────────
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ──────────────── Docker ────────────────
*.log
docker-compose.override.yml

# ──────────────── Environment / Secrets ────────────────
.env
.env.*
!.env.example

# ──────────────── ML / Data ────────────────
*.pkl
*.joblib
*.h5
*.pt
*.onnx
mlruns/
mlartifacts/

# ──────────────── IDE / Editor ────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ──────────────── OS junk ────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ──────────────── Misc ────────────────
*.bak
*.tmp
*.temp
coverage/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pytest_cache/
